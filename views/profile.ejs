<%- include('_header') %>

<div class="container py-4 py-md-5">
    <div class="row">
        <!-- User Profile Card -->
        <div class="col-12 col-md-4 mb-4">
            <div class="card shadow-lg h-100">
                <div class="card-body text-center">
                    <div class="mb-3">
                        <i class="fas fa-user-circle" style="font-size: 64px; color: #007bff;"></i>
                    </div>
                    <h3 class="card-title"><%= user.name %></h3>
                    <p class="text-muted mb-3"><%= user.email %></p>
                    
                    <div class="mb-3">
                        <p class="text-secondary small">User ID: #<%= user.id %></p>
                    </div>

                    <div class="d-grid gap-2">
                        <a href="/logout" class="btn btn-danger btn-lg">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Liked Items Cart -->
        <div class="col-12 col-md-8">
            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-heart"></i> My Liked Items
                        <span class="badge bg-light text-dark ms-2" id="likedItemsCount">
                            <%= likedItems.length %>
                        </span>
                    </h4>
                </div>

                <div class="card-body">
                    <% if (locals.message) { %>
                        <div class="alert alert-info alert-dismissible fade show" role="alert">
                            <%= message %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    <% } %>

                    

                    <!-- Items List -->
                    <div id="itemsContainer">
                        <% if (likedItems.length > 0) { %>
                            <div class="row">
                                <% likedItems.forEach((item) => { %>
                                    <div class="col-12 col-md-6 mb-3">
                                        <div class="card h-100 border-0 shadow-sm">
                                            <% if (item.item_image) { %>
                                                <img src="<%= item.item_image %>" class="card-img-top" alt="<%= item.item_name %>" style="height: 200px; object-fit: cover;">
                                            <% } else { %>
                                                <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 200px;">
                                                    <i class="fas fa-image" style="font-size: 48px;"></i>
                                                </div>
                                            <% } %>
                                            <div class="card-body">
                                                <h5 class="card-title"><%= item.item_name %></h5>
                                                <p class="card-text text-muted"><%= item.item_description || 'No description' %></p>
                                                <p class="card-text">
                                                    <strong class="text-success fs-5">$<%= parseFloat(item.item_price).toFixed(2) %></strong>
                                                </p>
                                                <small class="text-muted">ID: <%= item.item_id %></small>
                                                <p class="text-muted small mt-2">
                                                    Added: <%= new Date(item.added_at).toLocaleDateString() %>
                                                </p>
                                            </div>
                                            <div class="card-footer bg-transparent">
                                                <button class="btn btn-danger btn-sm w-100 remove-item-btn" data-item-id="<%= item.item_id %>">
                                                    <i class="fas fa-trash"></i> Remove
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>

                            <!-- Cart Summary -->
                            <div class="card mt-4 bg-light">
                                <div class="card-body">
                                    <h5 class="card-title">Cart Summary</h5>
                                    <p class="mb-2">Total Items: <strong id="totalItems"><%= likedItems.length %></strong></p>
                                    <p class="mb-0">Total Price: <strong class="text-success fs-5" id="totalPrice">$<%= likedItems.reduce((sum, item) => sum + parseFloat(item.item_price), 0).toFixed(2) %></strong></p>
                                </div>
                            </div>
                        <% } else { %>
                            <div class="alert alert-info text-center py-4">
                                <i class="fas fa-heart-broken" style="font-size: 48px; opacity: 0.5;"></i>
                                <p class="mt-3">No liked items yet. Add items to get started!</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Local storage management for cart
const STORAGE_KEY = 'landmarketplace_cart';
const USER_ID = '<%= user.id %>';

// Initialize cart from local storage on page load
function initializeCart() {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored) {
        try {
            const cart = JSON.parse(stored);
            console.log('Cart loaded from local storage:', cart);
        } catch (e) {
            console.error('Error parsing cart from storage:', e);
        }
    }
}

// Save item to local storage
function saveToLocalStorage(item) {
    let cart = [];
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored) {
        try {
            cart = JSON.parse(stored);
        } catch (e) {
            cart = [];
        }
    }
    
    // Add item if not already in cart
    if (!cart.find(i => i.item_id === item.item_id)) {
        cart.push({
            ...item,
            timestamp: new Date().toISOString()
        });
        localStorage.setItem(STORAGE_KEY, JSON.stringify(cart));
    }
}

// Remove item from local storage
function removeFromLocalStorage(itemId) {
    let cart = [];
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored) {
        try {
            cart = JSON.parse(stored);
            cart = cart.filter(item => item.item_id !== itemId);
            localStorage.setItem(STORAGE_KEY, JSON.stringify(cart));
        } catch (e) {
            console.error('Error removing from local storage:', e);
        }
    }
}

// Add item to liked items
document.getElementById('addItemForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const itemData = {
        itemId: document.getElementById('itemId').value,
        itemName: document.getElementById('itemName').value,
        itemPrice: parseFloat(document.getElementById('itemPrice').value),
        itemImage: document.getElementById('itemImage').value || null,
        itemDescription: document.getElementById('itemDescription').value || null
    };

    // Save to local storage first
    saveToLocalStorage(itemData);

    try {
        const response = await fetch('/api/liked-items/add', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(itemData)
        });

        const result = await response.json();

        if (result.success) {
            // Show success message
            showNotification('Item added successfully!', 'success');
            
            // Reset form
            document.getElementById('addItemForm').reset();
            
            // Reload items
            setTimeout(() => {
                location.reload();
            }, 500);
        } else {
            showNotification(result.message || 'Error adding item', 'error');
        }
    } catch (error) {
        console.error('Error:', error);
        showNotification('Error adding item', 'error');
    }
});

// Remove item from liked items
document.querySelectorAll('.remove-item-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
        const itemId = e.currentTarget.dataset.itemId;
        
        if (confirm('Are you sure you want to remove this item?')) {
            // Remove from local storage
            removeFromLocalStorage(itemId);

            try {
                const response = await fetch('/api/liked-items/remove', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ itemId })
                });

                const result = await response.json();

                if (result.success) {
                    showNotification('Item removed successfully!', 'success');
                    
                    // Reload items
                    setTimeout(() => {
                        location.reload();
                    }, 500);
                } else {
                    showNotification(result.message || 'Error removing item', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showNotification('Error removing item', 'error');
            }
        }
    });
});

// Notification helper
function showNotification(message, type) {
    const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
    const alertHTML = `
        <div class="alert ${alertClass} alert-dismissible fade show" role="alert">
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    `;
    
    const container = document.querySelector('.card-body');
    const temp = document.createElement('div');
    temp.innerHTML = alertHTML;
    container.insertBefore(temp.firstElementChild, container.firstChild);
}

// Initialize on page load
initializeCart();
</script>

    </main>

