<%- include('_header') %>

<!-- Hero Section -->
<section class="hero py-4 py-md-5" style="background: linear-gradient(135deg, #2c5aa0 0%, #1a3a5c 100%); color: white;">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-6">
                <h1 class="display-5 display-md-4 fw-bold mb-3 mb-md-4">Find Your Perfect Land in Kenya</h1>
                <p class="lead mb-3 mb-md-4 fs-6 fs-md-5">Discover premium land opportunities across Kenya. Buy, sell, or lease agricultural and residential land with confidence.</p>
                <div class="d-grid gap-2 d-md-flex gap-md-3">
                    <a href="/listings" class="btn btn-warning btn-md">Browse Listings</a>
                    <a href="/login" class="btn btn-outline-light btn-md">Get Started</a>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <img src="/images/kentucky+farm+-+web+header.jpg" alt="Land" class="img-fluid rounded-lg">
            </div>
        </div>
    </div>
</section>

<!-- Search Section -->
<section class="py-4 py-md-5 bg-white">
    <div class="container">
        <h2 class="text-center mb-3 mb-md-4 fs-5 fs-md-2">Search Properties</h2>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <form class="search-form">
                    <div class="row g-2 g-md-3">
                        <div class="col-12 col-md-4">
                            <input type="text" class="form-control form-control-lg" placeholder="Location">
                        </div>
                        <div class="col-12 col-md-4">
                            <select class="form-select form-select-lg">
                                <option selected>Property Type</option>
                                <option>Agricultural</option>
                                <option>Residential</option>
                                <option>Commercial</option>
                                <option>Industrial</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-4">
                            <button type="submit" class="btn btn-primary btn-lg w-100">Search</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Featured Listings -->
<section class="py-4 py-md-5">
    <div class="container">
        <h2 class="text-center mb-4 mb-md-5 fs-5 fs-md-2">Featured Listings</h2>
        <div class="row g-3 g-md-4">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <img src="/images/nandi.jpg" class="card-img-top" alt="Property">
                    <div class="card-body">
                        <h5 class="card-title">5 Acres Agricultural Land</h5>
                        <p class="card-text text-muted">Nandi County, Western Kenya</p>
                        <p class="lead fw-bold text-primary">KES 5,000,000</p>
                        <p class="card-text small">
                            <i class="fas fa-expand"></i> 5 acres
                            <br>
                            <i class="fas fa-water"></i> With irrigation
                        </p>
                    </div>
                    <div class="card-footer bg-white">
                        <a href="#" class="btn btn-outline-primary btn-sm w-100">View Details</a>
                    </div>
                </div>
            </div>
            
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <img src="/images/nairobi.webp" class="card-img-top" alt="Property">
                    <div class="card-body">
                        <h5 class="card-title">1000 Sq.ft Residential Plot</h5>
                        <p class="card-text text-muted">Karen, Nairobi</p>
                        <p class="lead fw-bold text-primary">KES 8,500,000</p>
                        <p class="card-text small">
                            <i class="fas fa-expand"></i> 1000 sq.ft
                            <br>
                            <i class="fas fa-road"></i> Main road access
                        </p>
                    </div>
                    <div class="card-footer bg-white">
                        <a href="#" class="btn btn-outline-primary btn-sm w-100">View Details</a>
                    </div>
                </div>
            </div>
            
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <img src="/images/kitale.webp" class="card-img-top" alt="Property">
                    <div class="card-body">
                        <h5 class="card-title">2 Acres Commercial Space</h5>
                        <p class="card-text text-muted">Westlands, Nairobi</p>
                        <p class="lead fw-bold text-primary">KES 15,000,000</p>
                        <p class="card-text small">
                            <i class="fas fa-expand"></i> 2 acres
                            <br>
                            <i class="fas fa-city"></i> Near shopping mall
                        </p>
                    </div>
                    <div class="card-footer bg-white">
                        <a href="#" class="btn btn-outline-primary btn-sm w-100">View Details</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-4 py-md-5 bg-light">
    <div class="container">
        <h2 class="text-center mb-4 mb-md-5 fs-5 fs-md-2">Why Choose Us</h2>
        <div class="row g-3 g-md-4">
            <div class="col-6 col-md-3">
                <div class="text-center">
                    <div class="display-6 text-primary mb-3">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <h5>Verified Properties</h5>
                    <p class="text-muted">All listings are verified and legally compliant</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-center">
                    <div class="display-6 text-primary mb-3">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h5>Secure Transactions</h5>
                    <p class="text-muted">Protected buyer and seller agreements</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-center">
                    <div class="display-6 text-primary mb-3">
                        <i class="fas fa-users"></i>
                    </div>
                    <h5>Expert Support</h5>
                    <p class="text-muted">Professional guidance throughout your journey</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="text-center">
                    <div class="display-6 text-primary mb-3">
                        <i class="fas fa-mobile-alt"></i>
                    </div>
                    <h5>Easy to Use</h5>
                    <p class="text-muted">Simple and intuitive platform access</p>
                </div>
            </div>
        </div>
    </div>
</section>

