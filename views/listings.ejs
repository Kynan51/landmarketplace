<%- include('_header') %>

<!-- Page Header -->
<section class="py-3 py-md-4 bg-light border-bottom">
    <div class="container">
        <h1 class="mb-2 fs-5 fs-md-1">Property Listings</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active">Listings</li>
            </ol>
        </nav>
    </div>
</section>

<div class="container py-4 py-md-5">
    <div class="row g-3 g-md-4">
        <!-- Sidebar Filters -->
        <div class="col-12 col-lg-3 mb-3 mb-lg-0">
            <button class="btn btn-primary w-100 d-lg-none mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#filterPanel">
                <i class="fas fa-filter me-2"></i> Show Filters
            </button>
            <div id="filterPanel" class="collapse d-lg-block">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-filter"></i> Filters</h5>
                    </div>
                    <div class="card-body">
                        <form id="filterForm">
                            <!-- Property Type -->
                            <div class="mb-4">
                                <label class="form-label fw-bold small">Property Type</label>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="type1" value="agricultural">
                                    <label class="form-check-label" for="type1">Agricultural</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="type2" value="residential">
                                    <label class="form-check-label" for="type2">Residential</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="type3" value="commercial">
                                    <label class="form-check-label" for="type3">Commercial</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="type4" value="industrial">
                                    <label class="form-check-label" for="type4">Industrial</label>
                                </div>
                            </div>

                            <!-- Price Range -->
                            <div class="mb-4">
                                <label class="form-label fw-bold small">Price Range</label>
                                <input type="range" class="form-range" min="0" max="500000" step="10000" id="priceRange">
                                <small class="text-muted">$0 - $<span id="priceValue">500000</span></small>
                            </div>

                            <!-- Location -->
                            <div class="mb-4">
                                <label class="form-label fw-bold small">Location</label>
                                <input type="text" class="form-control form-control-sm" placeholder="City or District">
                            </div>

                            <!-- Size -->
                            <div class="mb-4">
                                <label class="form-label fw-bold small">Size Range</label>
                                <div class="input-group input-group-sm mb-2">
                                    <input type="number" class="form-control" placeholder="Min">
                                    <span class="input-group-text">-</span>
                                    <input type="number" class="form-control" placeholder="Max">
                                </div>
                                <small class="text-muted">in acres/sq.ft</small>
                            </div>

                            <!-- Buttons -->
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-sm">Apply Filters</button>
                                <button type="reset" class="btn btn-outline-secondary btn-sm">Reset</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Listings -->
        <div class="col-12 col-lg-9">
            <!-- View Toggle & Sort -->
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 mb-4">
                <div>
                    <span class="text-muted small">Showing 12 of 48 properties</span>
                </div>
                <div class="d-flex flex-column flex-md-row gap-2 w-100 w-md-auto">
                    <div>
                        <label class="form-label me-2 small d-none d-md-inline">Sort by:</label>
                    </div>
                    <select class="form-select form-select-sm" style="width: auto; min-width: 200px;">
                        <option>Newest</option>
                        <option>Price: Low to High</option>
                        <option>Price: High to Low</option>
                        <option>Size: Large to Small</option>
                        <option>Most Viewed</option>
                    </select>
                </div>
            </div>

            <!-- Property Grid -->
            <div class="row g-3 g-md-4">
                <!-- Property Card 1 -->
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm property-card">
                        <div class="position-relative">
                            <img src="/images/nandi.jpg" class="card-img-top" alt="Property">
                            <span class="badge bg-success position-absolute top-0 start-0 m-2">For Sale</span>
                            <button class="btn btn-light position-absolute top-0 end-0 m-2 rounded-circle">
                                <i class="fas fa-heart"></i>
                            </button>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">5 Acres Agricultural Land</h5>
                            <p class="text-muted small mb-2">
                                <i class="fas fa-map-marker-alt"></i> Rural Area, District
                            </p>
                            <p class="lead fw-bold text-primary mb-3">$50,000</p>
                            <div class="row text-center mb-3">
                                <div class="col-6 border-end">
                                    <small><i class="fas fa-expand"></i> 5 acres</small>
                                </div>
                                <div class="col-6">
                                    <small><i class="fas fa-water"></i> Irrigated</small>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white">
                            <a href="#" class="btn btn-primary btn-sm w-100">View Details</a>
                        </div>
                    </div>
                </div>

                <!-- Property Card 2 -->
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm property-card">
