                    </div>
                </div>

                <!-- Property Card 5 -->
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm property-card">
                        <div class="position-relative">
                            <img src="/images/mombasa legit.webp" class="card-img-top" alt="Property">
                            <span class="badge bg-info position-absolute top-0 start-0 m-2">For Lease</span>
                            <button class="btn btn-light position-absolute top-0 end-0 m-2 rounded-circle">
