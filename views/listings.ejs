                            <button class="btn btn-light position-absolute top-0 end-0 m-2 rounded-circle">
                                <i class="fas fa-heart"></i>
                            </button>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">1000 Sq.ft Residential Plot</h5>
                            <p class="text-muted small mb-2">
                                <i class="fas fa-map-marker-alt"></i> City Center, District
                            </p>
                            <p class="lead fw-bold text-primary mb-3">$75,000</p>
                            <div class="row text-center mb-3">
                                <div class="col-6 border-end">
                                    <small><i class="fas fa-expand"></i> 1000 sq.ft</small>
                                </div>
                                <div class="col-6">
                                    <small><i class="fas fa-road"></i> Main Road</small>
                                </div>
