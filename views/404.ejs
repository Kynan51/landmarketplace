<%- include('_header') %>

<style>
    :root {
        --primary-color: #2c5aa0;
        --secondary-color: #f39c12;
    }
    
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }
        
        .error-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }
        
        .error-content {
            text-align: center;
            background: white;
            border-radius: 20px;
            padding: 60px 40px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            max-width: 600px;
        }
        
        .error-code {
            font-size: 100px;
            font-weight: 900;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin: 0;
            line-height: 1;
        }

        @media (max-width: 576px) {
            .error-code {
                font-size: 80px;
            }

            .error-title {
                font-size: 24px !important;
            }

            .error-message {
                font-size: 14px !important;
            }

            .error-content {
                padding: 30px 20px !important;
            }

            .btn-back, .btn-home {
                padding: 10px 25px;
                font-size: 14px;
            }
        }
        
        .error-title {
            font-size: 32px;
            font-weight: 700;
            color: #2c3e50;
            margin: 20px 0 10px;
        }
        
        .error-message {
            color: #7f8c8d;
            font-size: 16px;
            margin-bottom: 30px;
            line-height: 1.6;
        }
        
        .error-icon {
            font-size: 80px;
            color: #667eea;
            margin-bottom: 20px;
            animation: float 3s ease-in-out infinite;
        }
        
     
        .error-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
        }

        @media (max-width: 576px) {
            .error-buttons {
                gap: 10px;
                flex-direction: column;
            }

            .error-buttons a {
                width: 100%;
            }
        }
        
        .btn-back {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            padding: 12px 40px;
            font-size: 16px;
            font-weight: 600;
        }
        
        .btn-back:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.4);
        }
        
        .btn-home {
            background: white;
            color: #667eea;
            border: 2px solid #667eea;
            padding: 12px 40px;
            font-size: 16px;
            font-weight: 600;
        }
        
        .btn-home:hover {
            background: #667eea;
            color: white;
            transform: translateY(-3px);
        }
        
        footer {
            background-color: #2c3e50;
            color: white;
            padding: 30px 0 20px;
            margin-top: auto;
        }
        
        .illustration {
            max-width: 300px;
            margin: 0 auto 30px;
            opacity: 0.8;
        }
    </style>

    <!-- Error Content -->
    <div class="error-container">
        <div class="error-content">
            <div class="error-icon">
                <i class="fas fa-map-location-dot"></i>
            </div>
            
            <h1 class="error-code">404</h1>
            <h2 class="error-title">Page Not Found</h2>
            <p class="error-message">
                Sorry! We couldn't find the property or page you're looking for. It might have been moved, deleted, or the URL might be incorrect.
            </p>
            
            <div class="error-buttons">
                <a href="/" class="btn btn-back btn-lg text-white">
                    <i class="fas fa-home"></i> Go to Home
                </a>
                <a href="/listings" class="btn btn-home btn-lg">
                    <i class="fas fa-search"></i> Browse Listings
                </a>
            </div>
            
            
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div class="text-center text-white-50">
                <p>&copy; 2026 Land Marketplace. All rights reserved.</p>
                <small>
                    <a href="/privacy" class="text-decoration-none text-white-50 me-3">Privacy Policy</a>
                    <a href="/terms" class="text-decoration-none text-white-50">Terms of Service</a>
                </small>
            </div>
        </div>
    </footer>
